{#- scaffold-repo: deps -#}
cmake_minimum_required(VERSION {{ cmake_min_version | default("3.20") }})

project({{ project_snake }}
  VERSION {{ version | default("1.0.0") }}
  LANGUAGES {{ language | default("C") }}
)

# ── Variant selection for consuming dependencies ───────────────
set(A_BUILD_VARIANT "{{ default_variant | default("static") }}" CACHE STRING
    "Library variant to link against (debug|memory|static|shared)")
set_property(CACHE A_BUILD_VARIANT PROPERTY STRINGS debug memory static shared)

if(MSVC)
  set(_A_DEBUG_OPTS /Zi /Od)
  set(_A_RELEASE_OPTS /O2 /DNDEBUG)
else()
  set(_A_DEBUG_OPTS -O0 -g)
  set(_A_RELEASE_OPTS -O3 -DNDEBUG)
endif()

include(GNUInstallDirs)

# ---- Global Dependencies ----
{% for fp in deps.find_packages | default([]) %}
find_package({{ fp }})
{% endfor %}

{% if deps.pkg_config_deps %}
find_package(PkgConfig REQUIRED)
{% for dep in deps.pkg_config_deps %}
pkg_check_modules(PC_{{ dep.target | upper }} REQUIRED IMPORTED_TARGET {{ dep.module }})
if(NOT TARGET {{ dep.target }})
  add_library({{ dep.target }} ALIAS PkgConfig::PC_{{ dep.target | upper }})
endif()
{% endfor %}
{% endif %}

# ── Application Executables ───────────────────────────────────────────────────

{% for main_ctx in main.values() %}
{% for tgt in main_ctx.targets %}
add_executable({{ tgt.name }}
{% for s in tgt.sources %}
  {{ s }}
{% else %}
  src/main.c
{% endfor %}
)

target_include_directories({{ tgt.name }} PRIVATE
  $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>
{% for d in tgt.include_dirs | default([]) %}
  $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/{{ d }}>
{% endfor %}
)

set_target_properties({{ tgt.name }} PROPERTIES
  C_STANDARD {{ tgt.c_standard | default(c_standard) | default(23) }}
  C_STANDARD_REQUIRED YES
)

if("CXX" IN_LIST CMAKE_PROJECT_LANGUAGES)
  set_target_properties({{ tgt.name }} PROPERTIES
    CXX_STANDARD {{ tgt.cxx_standard | default(cxx_standard) | default(17) }}
    CXX_STANDARD_REQUIRED YES
  )
endif()

target_link_libraries({{ tgt.name }} PRIVATE
{% for l in main_ctx.link_libraries | default([]) %}
  {{ l }}
{% endfor %}
)

target_compile_options({{ tgt.name }} PRIVATE
  $<$<CONFIG:Debug>:${_A_DEBUG_OPTS}>
  $<$<NOT:$<CONFIG:Debug>>:${_A_RELEASE_OPTS}>
)

install(TARGETS {{ tgt.name }}
  RUNTIME DESTINATION ${CMAKE_INSTALL_BINDIR}
)
{% endfor %}
{% endfor %}

# Extra project-specific targets
{{ extra_targets | default("") }}

{% if tests %}
enable_testing()
{% endif %}

# Dynamically mount all subprojects (apps, examples, tests, etc.)
{% for subdir in active_subprojects | default([]) %}
add_subdirectory({{ subdir }})
{% endfor %}