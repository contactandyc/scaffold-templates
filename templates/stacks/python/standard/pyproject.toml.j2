{#- scaffold-repo: { dest: "pyproject.toml" } -#}
[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[project]
name = "{{ project_snake }}"
version = "{{ version | default('0.1.0') }}"

# ── External Dependencies ──
# Add your standard PyPI packages here.
# NOTE: The 'depends_on' array in scaffold.yaml is ONLY needed for
# internal/custom dependencies that must be built locally from source.
dependencies = [
    # Examples:
    # "requests>=2.31.0",
    # "fastapi>=0.100.0",
    # "pydantic>=2.0",
]

{% if is_cli_app == "CLI Application" %}
# ── CLI Entrypoint ──
# Exposes the CLI command globally when installed
[project.scripts]
{{ project_slug }} = "{{ project_snake }}.__main__:main"
{% endif %}
