{#- scaffold-repo: { dest: "build-image.pkr.hcl", updatable: true } -#}
packer {
  required_plugins {
    googlecompute = {
      version = ">= 1.1.4"
      source  = "github.com/hashicorp/googlecompute"
    }
  }
}

source "googlecompute" "marketplace_base" {
  project_id          = "{{ gcp_project_id | default('YOUR_GCP_PROJECT_ID') }}"
  zone                = "{{ gcp_zone | default('us-central1-a') }}"
  machine_type        = "{{ gcp_machine_type | default('c2-standard-4') }}"

  source_image_family = "{{ ubuntu_image_family | default('ubuntu-2204-lts') }}"
  disk_size           = {{ gcp_disk_size_gb | default('20') }}

  ssh_username        = "packer"

  image_name          = "{{ project_slug }}-v{{ version | default('0.1.0') | replace('.', '-') }}-{% raw %}{{timestamp}}{% endraw %}"
  image_family        = "{{ project_slug }}-family"
  image_description   = "GCP Marketplace Image for {{ project_title }}"
}

build {
  sources = ["source.googlecompute.marketplace_base"]

  provisioner "file" {
    source      = "setup-vm.sh"
    destination = "/tmp/setup-vm.sh"
  }

  provisioner "shell" {
    inline = [
      "chmod +x /tmp/setup-vm.sh",
      "sudo /tmp/setup-vm.sh"
    ]
  }
}
