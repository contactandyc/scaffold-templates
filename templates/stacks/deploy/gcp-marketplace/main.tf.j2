{#- scaffold-repo: { dest: "main.tf", updatable: true } -#}
terraform {
  required_providers {
    google = {
      source  = "hashicorp/google"
      version = "~> 5.0"
    }
  }
}

provider "google" {
  project = "{{ gcp_project_id | default('YOUR_GCP_PROJECT_ID') }}"
  region  = "{{ gcp_region | default('us-central1') }}"
  zone    = "{{ gcp_zone | default('us-central1-a') }}"
}

# ── Variables ──
variable "gcp_project_id" {
  description = "The GCP project ID"
  type        = string
  default     = "{{ gcp_project_id | default('YOUR_GCP_PROJECT_ID') }}"
}

variable "gcp_region" {
  description = "The GCP region"
  type        = string
  default     = "{{ gcp_region | default('us-central1') }}"
}

variable "gcp_zone" {
  description = "The GCP zone"
  type        = string
  default     = "{{ gcp_zone | default('us-central1-a') }}"
}

variable "machine_type" {
  description = "The Compute-Optimized machine type"
  type        = string
  default     = "{{ gcp_machine_type | default('c2-standard-4') }}"
}

variable "disk_size_gb" {
  description = "Boot disk size in GB"
  type        = number
  default     = {{ gcp_disk_size_gb | default('20') }}
}

# ── Data Sources ──
data "google_compute_image" "marketplace_image" {
  family  = "{{ project_slug }}-family"
  project = var.gcp_project_id
}

# ── Infrastructure ──
resource "google_compute_instance" "app_vm" {
  name         = "{{ project_slug }}-vm"
  machine_type = var.machine_type
  zone         = var.gcp_zone

  boot_disk {
    initialize_params {
      image = data.google_compute_image.marketplace_image.self_link
      type  = "pd-ssd"
      size  = var.disk_size_gb
    }
  }

  network_interface {
    network = "default"
    access_config {
      # Ephemeral public IP
    }
  }

  tags = ["{{ project_slug }}", "marketplace-app"]

  scheduling {
    automatic_restart   = true
    on_host_maintenance = "MIGRATE"
  }
}
