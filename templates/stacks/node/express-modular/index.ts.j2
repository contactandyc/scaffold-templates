import express from 'express';
import cors from 'cors';
import dotenv from 'dotenv';
{% if include_websockets == 'yes' %}
import http from 'http';
{% endif %}
import healthRouter from './routes/health';
{% if kv_backend != 'None' %}
import storeRouter from './routes/store';
import { init as initStore } from './services/store';
{% endif %}
{% if include_external_api == 'yes' %}
import externalRouter from './routes/external';
{% endif %}
{% if include_websockets == 'yes' %}
import { setupWebSockets } from './websockets';
{% endif %}

dotenv.config();

const app = express();
const port = process.env.PORT || 8080;

{% if include_websockets == 'yes' %}
// Wrap Express in a native Node HTTP server to attach Socket.io
const server = http.createServer(app);
setupWebSockets(server);
{% endif %}

app.use(cors());
app.use(express.json());

// Mount the modular routes
app.use('/api/health', healthRouter);
{% if kv_backend != 'None' %}
app.use('/api/store', storeRouter);
{% endif %}
{% if include_external_api == 'yes' %}
app.use('/api/proxy', externalRouter);
{% endif %}

{% if kv_backend != 'None' %}
initStore().then(() => {
  {% if include_websockets == 'yes' %}
  server.listen(port, () => {
  {% else %}
  app.listen(port, () => {
  {% endif %}
    console.log(`🚀 {{ project_slug }} server is running on http://localhost:${port}`);
  });
}).catch((err{% if use_typescript == 'yes' %}: any{% endif %}) => {
  console.error("Failed to initialize store:", err);
  process.exit(1);
});
{% else %}
{% if include_websockets == 'yes' %}
server.listen(port, () => {
{% else %}
app.listen(port, () => {
{% endif %}
  console.log(`🚀 {{ project_slug }} server is running on http://localhost:${port}`);
});
{% endif %}
