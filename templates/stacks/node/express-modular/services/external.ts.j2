// Demonstrates how to make outbound REST calls using native fetch
export const fetchUserData = async (userId{% if use_typescript == 'yes' %}: string{% endif %}){% if use_typescript == 'yes' %}: Promise<any>{% endif %} => {
  const response = await fetch(`https://jsonplaceholder.typicode.com/users/${userId}`);

  if (!response.ok) {
    throw new Error(`Failed to fetch external data: ${response.statusText}`);
  }

  return await response.json();
};
{% endif %}
