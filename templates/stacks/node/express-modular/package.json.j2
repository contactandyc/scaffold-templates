{#- scaffold-repo: { dest: "package.json" } -#}
{
  "name": "{{ project_slug }}",
  "version": "{{ version | default('0.1.0') }}",
  "description": "{{ description | default('A dynamically scaffolded node/express-modular project') }}",
  "main": "dist/index.js",
  "scripts": {
    {% if use_typescript == 'yes' %}
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint . --ext js,ts"
    {% else %}
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "lint": "eslint . --ext js"
    {% endif %}
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
    {%- if kv_backend == 'redis' %},
    "redis": "^4.6.13"
    {%- elif kv_backend == 'postgres' %},
    "pg": "^8.11.3"
    {%- endif %}
    {%- if include_websockets == 'yes' %},
    "socket.io": "^4.7.5"
    {% endif %}
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "nodemon": "^3.1.0"
    {%- if use_typescript == 'yes' %},
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
    {%- if kv_backend == 'postgres' %},
    "@types/pg": "^8.11.2"
    {%- endif %}
    {% endif %}
  }
}
